generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String
  companyId  String
  createdAt  DateTime @default(now())
  approverId String?
  role       Role     @default(USER)
}

enum Role {
  USER
  APPROVER
  ADMIN
}
