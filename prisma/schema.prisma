generator client {
  provider = "prisma-client"
  output   = "../app/(app)/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  password   String

  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])

  approverId String?
  approver   User?    @relation("ApproverRelation", fields: [approverId], references: [id])
  delegates  User[]   @relation("ApproverRelation")

  role       Role     @default(USER)
  createdAt  DateTime @default(now())

  isActive   Boolean  @default(true)
}

model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())

  isActive  Boolean  @default(true)
}

enum Role {
  USER
  APPROVER
  ADMIN
}
