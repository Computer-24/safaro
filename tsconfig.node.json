{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": false,
    "outDir": "dist-node",
    "noEmit": false
  },
  "include": ["prisma/**/*.ts", "scripts/**/*.ts", "lib/**/*.ts"]
}
